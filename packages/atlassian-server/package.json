{
  "name": "atlassian-server",
  "version": "0.2.0",
  "description": "MCP server for private/self-hosted Atlassian Jira and Confluence instances (Data Center/Server)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "atlassian-mcp-private": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "validate": "tsc --noEmit && eslint src/ test/ && vitest run && prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "ci": "tsc --noEmit && eslint src/ test/ && vitest run --coverage && prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "typescript-eslint": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
